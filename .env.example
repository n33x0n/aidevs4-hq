# AI_devs 4 — zmienne środowiskowe
# Skopiuj do .env i uzupełnij swoimi kluczami

# Wymagane
AIDEVS_API_KEY=your-api-key-here
OPENROUTER_API_KEY=sk-or-v1-...

# Langfuse — observability wywołań LLM (opcjonalne)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Azyl VPS — SSH do zadań wymagających serwera (opcjonalne)
AZYL_PASSWORD=
AZYL_REMOTE_PORT=

# Circle.so — panel powiadomień z platformy kursu (opcjonalne)
CIRCLE_COOKIES=
CIRCLE_EMAIL=

# ElevenLabs — TTS dla zadania S05E02 PhoneCall (opcjonalne)
ELEVENLABS_API_KEY=
